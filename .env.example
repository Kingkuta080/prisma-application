# =============================================================================
# Parent Portal — environment variables
# Copy to .env.local and fill in values. Do not commit .env or .env.local.
# =============================================================================

# -----------------------------------------------------------------------------
# Database
# -----------------------------------------------------------------------------
DATABASE_URL="postgresql://user:password@localhost:5432/sep?schema=public"

# -----------------------------------------------------------------------------
# Auth (NextAuth / Auth.js)
# -----------------------------------------------------------------------------
AUTH_SECRET="generate-with-openssl-rand-base64-32"
NEXTAUTH_URL="http://localhost:3000"
APP_URL="http://localhost:3000"

# Optional: for OpenAPI spec server URL when request origin is not available
# NEXT_PUBLIC_APP_URL="http://localhost:3000"

# -----------------------------------------------------------------------------
# Website content & branding (NEXT_PUBLIC_* are exposed to the browser)
# -----------------------------------------------------------------------------
NEXT_PUBLIC_SCHOOL_NAME="School Enrollment Platform"
NEXT_PUBLIC_SCHOOL_DESCRIPTION="Parent portal for school enrollment"
NEXT_PUBLIC_SCHOOL_LOGO="/logo.png"

# Colors: use HSL like "240 57% 27%" or hex like "#24136c"
NEXT_PUBLIC_COLOR_PRIMARY="240 57% 27%"
NEXT_PUBLIC_COLOR_SECONDARY="197 67% 44%"
NEXT_PUBLIC_COLOR_ACCENT="197 67% 44%"

# -----------------------------------------------------------------------------
# Google Sign-In (optional)
# -----------------------------------------------------------------------------
# AUTH_GOOGLE_ID=""
# AUTH_GOOGLE_SECRET=""

# -----------------------------------------------------------------------------
# Email (verification emails)
# -----------------------------------------------------------------------------
# SMTP_HOST="smtp.example.com"
# SMTP_PORT="587"
# SMTP_SECURE="false"
# SMTP_USER=""
# SMTP_PASSWORD=""
# MAIL_FROM="noreply@example.com"

# -----------------------------------------------------------------------------
# Payment
# -----------------------------------------------------------------------------
# Public URL of your payment gateway service
# GATEWAY_PUBLIC_URL="https://your-gateway.example.com"
# PAYMENT_QUEUE_NAME="prisma_app_payments"
# WEBHOOK_PAYMENT_SECRET=""

# -----------------------------------------------------------------------------
# Cloudinary (photo uploads)
# -----------------------------------------------------------------------------
# CLOUDINARY_CLOUD_NAME="your-cloud-name"
# CLOUDINARY_API_KEY="your-api-key"
# CLOUDINARY_API_SECRET="your-api-secret"

# -----------------------------------------------------------------------------
# Admin API (optional)
# -----------------------------------------------------------------------------
# ADMIN_API_KEY=""

# -----------------------------------------------------------------------------
# Vercel sets VERCEL_URL automatically; no need to set APP_URL there if you set NEXTAUTH_URL.
# -----------------------------------------------------------------------------
